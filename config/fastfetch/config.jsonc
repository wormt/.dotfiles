{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "modules": [
    "title",
    "os",
    "host",
    "kernel",
    "shell",
    "de",
    "wm",
    "terminal",
    "terminalfont",
    "cpu",
    "memory",
    "physicaldisk",
    "swap",
    {
      "type": "disk",
      "folders": "/:/var/home",
    },
    "packages",
    "uptime",
    "break",
    "colors",
  ],
}
